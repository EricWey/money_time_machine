.time-page {
  min-height: 100vh;
  padding: 36rpx 28rpx 56rpx;
  background:
    radial-gradient(circle at top, rgba(244, 218, 168, 0.38), transparent 28%),
    linear-gradient(180deg, #ead7b4 0%, #d9bf96 42%, #c6a57c 100%);
  color: #3d2b1f;
}

.hero {
  position: relative;
  margin-bottom: 28rpx;
  padding: 44rpx 24rpx 18rpx;
  text-align: center;
}

.hero-badge {
  display: inline-block;
  margin-bottom: 20rpx;
  padding: 8rpx 18rpx;
  border: 2rpx solid rgba(92, 50, 30, 0.36);
  border-radius: 999rpx;
  background: rgba(255, 248, 231, 0.55);
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #7a5237;
}

.hero-title {
  display: block;
  font-size: 68rpx;
  line-height: 1.06;
  letter-spacing: 6rpx;
  font-weight: 700;
  color: #5a2f1f;
  text-shadow: 0 8rpx 16rpx rgba(86, 50, 32, 0.12);
}

.hero-subtitle {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #6d4c36;
}

.hero-ornament {
  position: absolute;
  top: 26rpx;
  width: 88rpx;
  height: 88rpx;
  border: 3rpx solid rgba(101, 56, 35, 0.2);
  border-radius: 50%;
}

.hero-ornament::before,
.hero-ornament::after {
  content: '';
  position: absolute;
  inset: 16rpx;
  border: 2rpx dashed rgba(101, 56, 35, 0.22);
  border-radius: 50%;
}

.hero-ornament-left {
  left: 8rpx;
}

.hero-ornament-right {
  right: 8rpx;
}

.converter-card {
  position: relative;
  overflow: hidden;
  padding: 42rpx 28rpx 30rpx;
  border: 3rpx solid rgba(94, 55, 35, 0.16);
  border-radius: 32rpx;
  background:
    linear-gradient(160deg, rgba(255, 248, 236, 0.96), rgba(241, 223, 193, 0.92)),
    #f4e6c7;
  box-shadow: 0 20rpx 40rpx rgba(83, 51, 33, 0.14);
}

.converter-card::before {
  content: '';
  position: absolute;
  inset: 16rpx;
  border: 2rpx dashed rgba(120, 80, 52, 0.18);
  border-radius: 24rpx;
  pointer-events: none;
}

.card-stamp {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  transform: rotate(8deg);
  padding: 10rpx 16rpx;
  border: 2rpx solid rgba(121, 42, 31, 0.3);
  color: #8d4331;
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.mode-tag {
  position: relative;
  z-index: 1;
  display: inline-block;
  margin-bottom: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(122, 82, 55, 0.1);
  color: #7b553c;
  font-size: 20rpx;
}

.field-grid {
  display: flex;
  gap: 20rpx;
}

.field-group {
  position: relative;
  z-index: 1;
  margin-bottom: 24rpx;
}

.field-group.compact {
  flex: 1;
  margin-bottom: 28rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #69452f;
}

.money-input,
.selector {
  display: flex;
  align-items: center;
  min-height: 94rpx;
  padding: 0 24rpx;
  border: 2rpx solid rgba(97, 61, 40, 0.16);
  border-radius: 24rpx;
  background: rgba(255, 252, 245, 0.88);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.7);
}

.currency-symbol {
  margin-right: 14rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #7d462b;
}

.money-field {
  flex: 1;
  height: 94rpx;
  font-size: 30rpx;
  color: #402819;
}

.field-placeholder {
  color: #b69675;
}

.selector {
  justify-content: space-between;
}

.selector-value {
  font-size: 30rpx;
  color: #402819;
}

.selector-arrow {
  font-size: 26rpx;
  color: #7d462b;
}

.convert-button {
  position: relative;
  z-index: 1;
  height: 110rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #8b4f33 0%, #5f331d 100%);
  color: #fbe9d3;
  box-shadow: 0 16rpx 24rpx rgba(85, 49, 30, 0.22);
}

.convert-button::after {
  border: none;
}

.button-main,
.button-sub {
  display: block;
  line-height: 1.2;
}

.button-main {
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.button-sub {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(251, 233, 211, 0.82);
}

.inline-error {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #b1412d;
}

.loading-overlay {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(53, 31, 21, 0.74);
  backdrop-filter: blur(4px);
}

.loading-screen {
  width: 540rpx;
  padding: 38rpx 30rpx 34rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #4e362d, #2b201b);
  box-shadow: 0 24rpx 48rpx rgba(0, 0, 0, 0.28);
  text-align: center;
}

.tv-frame {
  position: relative;
  overflow: hidden;
  height: 280rpx;
  margin-bottom: 28rpx;
  border: 12rpx solid #8b674d;
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, rgba(255, 252, 244, 0.16), rgba(10, 10, 10, 0.44)),
    #1f1f1f;
}

.noise-layer {
  position: absolute;
  inset: 0;
  background:
    repeating-radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.18) 0 4rpx, transparent 4rpx 12rpx),
    repeating-radial-gradient(circle at 76% 58%, rgba(255, 255, 255, 0.16) 0 5rpx, transparent 5rpx 14rpx),
    linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.02));
  animation: noiseFlicker 0.5s steps(3) infinite;
}

.scan-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 80rpx;
  background: linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.25), transparent);
  animation: scanMove 0.5s linear infinite;
}

.loading-year {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  letter-spacing: 10rpx;
  color: #f2d7b1;
  text-shadow: 0 0 20rpx rgba(250, 236, 210, 0.4);
}

.loading-text {
  display: block;
  font-size: 30rpx;
  color: #f4dfc4;
}

.loading-tip {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: rgba(244, 223, 196, 0.68);
}

.result-section {
  margin-top: 30rpx;
}

.result-panel {
  padding: 34rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 249, 238, 0.96), rgba(239, 225, 198, 0.92));
  box-shadow: 0 16rpx 32rpx rgba(83, 51, 33, 0.12);
}

.section-kicker {
  display: block;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #8b5f43;
}

.result-title,
.result-value,
.result-arrow {
  display: block;
  text-align: center;
}

.result-title {
  font-size: 38rpx;
  color: #67412c;
}

.result-arrow {
  margin: 8rpx 0;
  font-size: 42rpx;
  color: #8d5e39;
}

.result-value {
  font-size: 60rpx;
  font-weight: 700;
  color: #5a2f1f;
}

.result-meta {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #6e4d39;
}

.matrix-section {
  margin-top: 24rpx;
}

.matrix-header {
  margin-bottom: 16rpx;
  padding: 0 6rpx;
}

.matrix-subtitle {
  display: block;
  font-size: 24rpx;
  color: #704d39;
}

.matrix-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -9rpx;
}

.matrix-card {
  flex: 1 1 300rpx;
  margin: 0 9rpx 18rpx;
  padding: 22rpx;
  border: 2rpx solid rgba(110, 75, 49, 0.12);
  border-radius: 24rpx;
  background: rgba(255, 251, 244, 0.92);
  box-shadow: 0 12rpx 26rpx rgba(83, 51, 33, 0.08);
}

.matrix-image-frame {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 160rpx;
  margin-bottom: 18rpx;
  border-radius: 20rpx;
  background:
    linear-gradient(180deg, rgba(133, 95, 69, 0.08), rgba(133, 95, 69, 0.16)),
    #efe0c4;
}

.matrix-image {
  width: 120rpx;
  height: 120rpx;
  filter: sepia(0.3);
}

.matrix-title {
  display: block;
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #5e3b28;
}

.matrix-price,
.matrix-comparison,
.matrix-note {
  display: block;
  font-size: 22rpx;
  line-height: 1.7;
}

.matrix-price {
  color: #714d37;
}

.matrix-price.current {
  color: #8a4b30;
}

.matrix-comparison {
  margin-top: 8rpx;
  color: #5d3627;
  font-weight: 700;
}

.matrix-note {
  margin-top: 8rpx;
  color: #80624a;
}

.newspaper-section {
  position: relative;
  overflow: hidden;
  margin-top: 26rpx;
  padding: 34rpx 28rpx 28rpx;
  border: 2rpx solid rgba(124, 96, 64, 0.24);
  border-radius: 22rpx;
  background:
    linear-gradient(180deg, rgba(244, 234, 209, 0.98), rgba(231, 215, 181, 0.96)),
    #efe1c3;
  box-shadow: 0 16rpx 28rpx rgba(83, 51, 33, 0.1);
}

.newspaper-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(90deg, rgba(140, 110, 78, 0.05) 0 2rpx, transparent 2rpx 100%),
    linear-gradient(180deg, rgba(140, 110, 78, 0.05) 0 2rpx, transparent 2rpx 100%);
  background-size: 18rpx 18rpx;
  opacity: 0.35;
  pointer-events: none;
}

.paper-fold {
  position: absolute;
  top: 0;
  right: 0;
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(114, 86, 58, 0.18));
  clip-path: polygon(100% 0, 0 0, 100% 100%);
}

.newspaper-label,
.newspaper-title,
.newspaper-body,
.newspaper-footer {
  position: relative;
  z-index: 1;
}

.newspaper-label {
  display: block;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: #8b6547;
}

.newspaper-title {
  display: block;
  margin-top: 10rpx;
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #433025;
}

.newspaper-body {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.95;
  color: #4a392d;
  text-align: justify;
}

.newspaper-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 2rpx dashed rgba(113, 78, 55, 0.28);
}

.newspaper-date,
.newspaper-stamp {
  font-size: 22rpx;
  color: #7b563d;
}

.newspaper-stamp {
  padding: 6rpx 12rpx;
  border: 2rpx solid rgba(139, 67, 49, 0.26);
  transform: rotate(-5deg);
}

@keyframes scanMove {
  0% {
    top: -80rpx;
  }

  100% {
    top: 280rpx;
  }
}

@keyframes noiseFlicker {
  0% {
    opacity: 0.62;
  }

  50% {
    opacity: 0.9;
  }

  100% {
    opacity: 0.7;
  }
}

.hero-title {
  word-break: keep-all;
}

.field-grid {
  flex-wrap: wrap;
}

.field-group.compact {
  min-width: 0;
}
